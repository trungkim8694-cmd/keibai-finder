generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  sale_unit_id         String            @id
  source_provider      String            @default("BIT")
  source_url           String?
  court_name           String
  property_type        String
  address              String
  prefecture           String?
  city                 String?
  lat                  Float?
  lng                  Float?
  starting_price       BigInt?
  status               String            @default("ACTIVE")
  views                Int               @default(dbgenerated("(floor(((random() * (601)::double precision) + (200)::double precision)))::integer"))
  thumbnailUrl         String?
  pdf_url              String?
  raw_display_data     Json?
  raw_text             String?
  ai_analysis          Json?
  ai_status            String?           @default("PENDING_AI")
  build_year_western   Int?
  images               String[]
  area                 Float?
  bid_start_date       DateTime?
  bid_end_date         DateTime?
  managing_authority   String?
  line_name            String?
  nearest_station      String?
  distance_to_station  Int?
  walk_time_to_station Int?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  mlit_estimated_price BigInt?
  mlit_investment_gap  Float?
  auction_history      AuctionHistory[]
  auction_events       AuctionSchedule[]

  @@index([lat, lng])
  @@index([prefecture])
  @@index([area])
  @@index([bid_start_date])
  @@index([bid_end_date])
  @@index([line_name])
  @@index([nearest_station])
  @@index([walk_time_to_station])
  @@index([managing_authority])
  @@index([views])
  @@index([created_at])
  @@index([mlit_investment_gap], map: "idx_property_mlit_gap")
}

model AuctionHistory {
  id            String   @id @default(uuid())
  sale_unit_id  String
  price         BigInt?
  round_name    String?
  drop_percent  Float?
  discovered_at DateTime @default(now())
  property      Property @relation(fields: [sale_unit_id], references: [sale_unit_id], onDelete: Cascade)
}

model AuctionSchedule {
  id             String    @id @default(uuid())
  sale_unit_id   String
  bid_start_date DateTime?
  bid_end_date   DateTime?
  open_date      DateTime?
  property       Property  @relation(fields: [sale_unit_id], references: [sale_unit_id], onDelete: Cascade)
}

model AuctionResult {
  id               String    @id @default(uuid())
  sale_unit_id     String?   @unique
  caseNumber       String
  address          String?
  lat              Float?
  lng              Float?
  basePrice        BigInt?
  winningPrice     BigInt?
  bidderCount      Int?
  winnerType       String?
  marginRate       Float?
  competitionLevel String?
  completionDate   DateTime?
  raw_data         Json?
  created_at       DateTime  @default(now())

  @@index([lat, lng])
}

model RailwayStation {
  id         String   @id @default(uuid())
  name_ja    String
  line_name  String?
  lat        Float
  lng        Float
  created_at DateTime @default(now())

  @@index([lat, lng])
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  accounts      Account[]
  comments      Comment[]
  favorites     Favorite[]
  sessions      Session[]
  memos         UserMemo[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id           String   @id @default(cuid())
  userId       String
  sale_unit_id String
  created_at   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sale_unit_id])
}

model UserMemo {
  id           String   @id @default(cuid())
  userId       String
  sale_unit_id String
  content      String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sale_unit_id])
}

model Comment {
  id           String   @id @default(cuid())
  userId       String
  sale_unit_id String
  content      String
  created_at   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MlitMarketCache {
  id               String   @id @default(cuid())
  municipalityCode String
  propertyType     String
  year             String
  avgTradePrice    BigInt?
  avgPricePerSqm   BigInt?
  avgArea          Float?
  transactions     Json?
  last_fetched_at  DateTime @default(now())

  @@unique([municipalityCode, propertyType, year])
  @@index([municipalityCode])
}

model DailyDigest {
  id             String    @id @default(cuid())
  slug           String    @unique
  publishDate    DateTime  @default(now())
  
  // SEO Metadata
  title_ja       String
  title_en       String
  title_vi       String
  title_zh       String
  
  // Cấu trúc Content phân mảnh (Lưu Markdown)
  content_ja     String    @db.Text
  content_en     String    @db.Text
  content_vi     String    @db.Text
  content_zh     String    @db.Text
  
  // Dữ liệu dùng dể Render React Shortcode và SEO Internal link
  tags           String[]  // ['saitama', 'tokyo', 'mansion']
  featuredImage  String?   // Ảnh Cover
  
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  
  @@index([publishDate])
  @@index([slug])
}
